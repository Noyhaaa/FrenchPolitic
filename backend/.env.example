# Copier en .env et adapter. Aucune valeur secrète ici.

# --- API ---
APP_ENV=dev
API_CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]

# --- Base de données (Phase 1) ---
# REPOSITORY_BACKEND=postgres        # "memory" (défaut, seed) ou "postgres"
# DATABASE_URL=postgresql+asyncpg://localhost:5432/frenchpolitics

# --- Sources officielles (Phase 1) ---
# AN_OPENDATA_BASE_URL=https://www.assemblee-nationale.fr/dyn/opendata
# PISTE Légifrance (OAuth2 client credentials) — inscription requise
# LEGIFRANCE_CLIENT_ID=
# LEGIFRANCE_CLIENT_SECRET=

# --- Génération IA (Phase 2) ---
# LLM_PROVIDER=mock                     # mock | ollama | (à venir) anthropic
# LLM_MODEL=mistral:latest              # modèle Ollama local ; ou claude-sonnet-5
# LLM_BASE_URL=http://localhost:11434   # serveur Ollama local
# ANTHROPIC_API_KEY=
# Usage actuel du LLM : classification de thème à l'ingestion (tâche à faible
# risque). PAS de prose neutre générée par LLM — un 7B local n'est pas assez
# fiable et les garde-fous lexicaux ne rattrapent pas ses biais (cf. README §IA).
